@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(nlohmann_json CONFIG REQUIRED)
find_dependency(spdlog        CONFIG REQUIRED)
find_dependency(fmt           CONFIG REQUIRED)
find_dependency(OpenSSL       CONFIG REQUIRED)
find_dependency(falcon-typing CONFIG REQUIRED)
find_dependency(FLEX REQUIRED)
find_dependency(BISON REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/falcon-dsl-targets.cmake")

check_required_components(falcon-dsl)
check_required_components(falcon-atc-core)
